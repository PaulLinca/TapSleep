<resources>
    <style name="AppTheme" parent="android:Theme.Material.NoActionBar" />

    <!-- System splash screen: Night sky + moon mark, transitions into AppTheme -->
    <style name="AppTheme.Splash" parent="Theme.SplashScreen">
        <!-- Dark Night background — matches brand #0A0D1A -->
        <item name="windowSplashScreenBackground">#0A0D1A</item>
        <!-- Inner icon circle same colour so there's no white ring on API 31+ -->
        <item name="windowSplashScreenIconBackgroundColor">#0A0D1A</item>
        <!-- Moon mark centred in the safe zone -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Hand off to the real app theme once Compose is ready -->
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
</resources>